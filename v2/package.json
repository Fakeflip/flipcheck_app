{
  "name": "flipcheck-v2",
  "version": "2.0.0",
  "description": "eBay Reseller Profitability Analysis",
  "author": "Marco Arnold",
  "repository": {
    "type": "git",
    "url": "https://github.com/Fakeflip/flipcheck_app.git"
  },
  "main": "main.js",
  "private": true,
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:mac": "electron-builder --mac --publish never",
    "build:win": "electron-builder --win --publish never",
    "release": "electron-builder --publish always",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "typecheck": "tsc --noEmit --project tsconfig.json"
  },
  "devDependencies": {
    "@electron/notarize": "^2.5.0",
    "electron": "^39.2.7",
    "electron-builder": "^24.9.1",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "discord-rpc": "^4.0.1",
    "dotenv": "^17.2.3",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.3.0",
    "keytar": "^7.9.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "inventory-logic.js",
      "settingsStore.js",
      "assets/lib/constants.js",
      "assets/lib/storage.js",
      "assets/app.js"
    ],
    "coverageDirectory": "coverage"
  },
  "build": {
    "appId": "app.flipcheck.desktop",
    "productName": "FLIPCHECK",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "settingsStore.js",
      "inventory-logic.js",
      "index.html",
      "assets/**",
      "package.json"
    ],
    "protocols": [
      {
        "name": "FLIPCHECK",
        "schemes": [
          "flipcheck"
        ]
      }
    ],
    "publish": {
      "provider": "github"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.icns",
      "category": "public.app-category.finance",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "notarize": {
        "teamId": "3S8CTWCYHT"
      }
    },
    "dmg": {
      "title": "FLIPCHECK ${version}",
      "sign": false
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false
    }
  }
}
